# Flutter/Dart specific
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock
.pub/
build/
.pub-cache/
*.dill
*.dill.track.dill
**/Generated.xcconfig
**/flutter_export_environment.sh

# FVM Version Cache
.fvm/

# Keep example folder structure but ignore build artifacts
example/build/
example/.dart_tool/
example/.flutter-plugins
example/.flutter-plugins-dependencies
example/.packages
example/pubspec.lock
example/.pub/
example/*.dill
example/*.dill.track.dill
example/.idea/
example/.vscode/
example/android/.cxx/
example/ios/Flutter/.last_build_id
example/ios/Flutter/App.framework/
example/ios/Flutter/Flutter.framework/
example/ios/Flutter/Flutter.podspec
example/ios/Flutter/Generated.xcconfig
example/ios/Flutter/flutter_export_environment.sh
example/ios/Pods/
example/ios/Runner.xcworkspace/

# Only ignore large assets, keep small ones
example/assets/**/*.wav
example/assets/**/*.mp3
example/assets/**/*.sf2
example/assets/**/*.sfz
# But ensure we keep some small example assets for demo purposes 
!example/assets/README.md

# Git objects in subdirectories
**/.git/

# iOS specific - these are usually large
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/App.framework
ios/Flutter/ephemeral/

# IDE specific
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Temporary files
*.swp
*.tmp
*.bak
*~

# Log files
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Don't ignore all of third_party, just the large parts
!android/third_party/sfizz/include/
!ios/third_party/sfizz/include/

# Add .gitkeep files to ensure directories are tracked
!**/example/**/.gitkeep